#!/bin/sh
set -eu

# Configuration
WIKI_LANG="${WIKI_LANG:-en}"
API="https://${WIKI_LANG}.wikipedia.org/w/api.php"
UA="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/wiki-cli"

mkdir -p "$CACHE_DIR"

# Detect terminal capabilities and user preferences for color
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    BOLD=$(printf '\033[1m')
    GREEN=$(printf '\033[32m')
    YELLOW=$(printf '\033[33m') 
    CYAN=$(printf '\033[36m')
    BLUE=$(printf '\033[34m')
    RESET=$(printf '\033[0m')
    DIM=$(printf '\033[2m')
else
    BOLD="" GREEN="" YELLOW="" CYAN="" BLUE="" RESET="" DIM=""
fi

usage() {
    cat <<EOF
Search and view Wikipedia articles directly in your shell.

Usage: 
  $(basename "$0") [OPTIONS] <query>

Options:
  -l <lang>    Specify language (e.g., en, es, fr, de, jp)
  -h, --help   Show this help menu

FZF Keybindings (in search):
  enter        Open full article
  ctrl-o       Open in web browser
  ctrl-y       Copy article URL to clipboard
  ctrl-r       Refresh search results

Examples:
  $(basename "$0") linux                # Standard search (English)
  $(basename "$0") -l es "Astronáutica" # Search in Spanish
EOF
}

check_deps() {
    for dep in curl jq fzf cksum awk; do
        if ! command -v "$dep" >/dev/null 2>&1; then
            echo "Missing dependency: $dep"
            exit 1
        fi
    done
}

get_width() { stty size 2>/dev/null | awk '{print $2}' || echo 80; }

# Helper to copy to clipboard
copy_to_clipboard() {
    if command -v wl-copy >/dev/null 2>&1; then echo -n "$1" | wl-copy
    elif command -v xclip >/dev/null 2>&1; then echo -n "$1" | xclip -selection clipboard
    elif command -v xsel >/dev/null 2>&1; then echo -n "$1" | xsel -ib
    elif command -v pbcopy >/dev/null 2>&1; then echo -n "$1" | pbcopy
    fi
}

# Preview helper function for fzf
preview_article() {
    title="$1"
    hash=$(echo "$title" | cksum | cut -d" " -f1)
    cache_file="$CACHE_DIR/$hash.txt"
    
    if [ ! -f "$cache_file" ]; then
        encoded_title=$(printf "%s" "$title" | jq -sRr @uri)
        url="$API?action=query&titles=$encoded_title&prop=extracts&explaintext=1&format=json&redirects=1"
        curl -sL --connect-timeout 3 "$url" | \
        jq -r ".query.pages | to_entries[0].value.extract // \"\"" > "$cache_file"
    fi

    if [ ! -s "$cache_file" ]; then
        echo "  (No summary available)"
        return
    fi

    printf "${YELLOW}${BOLD}SUMMARY: %s${RESET}\n${DIM}──────────────────────────────────────────${RESET}\n" "$title"
    
    if [ ! -s "$cache_file" ]; then
        echo "  (No summary available)"
        return
    fi

    awk -v dim="$DIM" -v reset="$RESET" '
        BEGIN { 
            pw = (ENVIRON["FZF_PREVIEW_COLUMNS"] ? ENVIRON["FZF_PREVIEW_COLUMNS"] : 50);
            indent = "  "; started = 0; finished = 0;
            l_count = 0; max_l = 7; ln = indent;
        }
        # Skip leading empty lines and headers
        !started && (/^[[:space:]]*$/ || /^==+/) { next }
        
        # Detect end of first paragraph (new header or empty line after start)
        started && (/^[[:space:]]*$/ || /^==+/) { finished = 1; exit }

        # Process first paragraph
        {
            started = 1
            gsub(/\[[0-9]+\]|\[[a-zA-Z ]+\]/, "", $0);
            gsub(/ ,/, ",", $0);
            gsub(/->/, "", $0);
            
            s = $0; gsub(/[[:space:]]+/, " ", s); sub(/^[[:space:]]+/, "", s);
            if (s == "") next;
            
            wd = pw - 4; n = split(s, words, " ");
            for (i = 1; i <= n; i++) {
                if (length(ln words[i]) > wd) {
                    print ln; l_count++;
                    ln = indent words[i] " ";
                    if (l_count >= max_l) { finished = 1; exit }
                } else { 
                    ln = ln words[i] " " 
                }
            }
        }
        END {
            if (!finished && started && ln != indent) {
                print ln; l_count++;
            }
            if (finished || started) {
                printf "%s  ... (Enter for full article)%s\n", dim, reset
            }
        }
    ' "$cache_file"
}

render() {
    W_VAL=$(awk -v c="$(get_width)" 'BEGIN { print int(c * 0.95) }')
    (
      printf "${CYAN}${BOLD} %s${RESET}\n${DIM} ─────────────────────────────────────────${RESET}\n" "$(printf '%s' "$1" | tr '[:lower:]' '[:upper:]')"
      printf "%s\n" "$2" | awk -v g="$GREEN" -v y="$YELLOW" -v c="$CYAN" -v b="$BOLD" -v r="$RESET" -v w="$W_VAL" -v d="$DIM" '
      BEGIN { e = 1; skip = 0; current_lvl = "  " }
      
      function h(l) {
          if (l ~ /^===== /) { gsub(/^===== /, "", l); gsub(/ =====$/, "", l); return "    " c b "▪ " toupper(l) r }
          if (l ~ /^==== /) { gsub(/^==== /, "", l); gsub(/ ====$/, "", l); return "    " c b "▪ " toupper(l) r }
          if (l ~ /^=== /)  { gsub(/^=== /, "", l);  gsub(/ ===$/, "", l);  return "  " y b "▸ " toupper(l) r }
          if (l ~ /^== /)   { gsub(/^== /, "", l);   gsub(/ ==$/, "", l);   return "\n" g b "── " toupper(l) r }
          return l
      }

      function wr(s, indent) {
          gsub(/[[:space:]]+/, " ", s); sub(/^[[:space:]]+/, "", s);
          if (s == "") return;
          wd = w - length(indent); n = split(s, wrds, " "); ln = indent
          for (i = 1; i <= n; i++) {
              if (length(ln wrds[i]) > wd) { print ln; ln = indent wrds[i] " " }
              else { ln = ln wrds[i] " " }
          }
          print ln
      }

      {
          if ($0 ~ /^==+ (See also|Notes|References|External links|Further reading|Bibliography|Sources|Notes et références|Véase también|Referenzen)/) { skip = 1; next }
          if (skip && $0 ~ /^==+ /) { skip = 0 }
          if (skip) next
          
          if ($0 ~ /^[[:space:]]*$/) { if (!e) { print ""; e = 1 }; next }
          e = 0; 
          
          if ($0 ~ /^==+ /) { 
              print h($0); 
              current_lvl = ($0 ~ /^====/) ? "      " : (($0 ~ /^===/) ? "    " : "  ");
              next 
          }

          gsub(/\[[0-9]+\]|\[[a-zA-Z ]+\]/, "", $0);
          gsub(/ ,/, ",", $0);
          gsub(/->/, "", $0);
          
          wr($0, current_lvl)
      }'
    ) | less -R
}

# Main execution logic
if [ $# -gt 0 ]; then
    case "$1" in
        --preview-internal)
            preview_article "$2"
            exit 0
            ;;
        -l) 
            if [ -n "${2:-}" ]; then
                WIKI_LANG="$2"
                API="https://${WIKI_LANG}.wikipedia.org/w/api.php"
                shift 2
            fi
            ;;
        -h|--help) usage; exit 0 ;;
    esac
fi

[ $# -eq 0 ] && { usage; exit 0; }
check_deps
QUERY="$*"

fetch_search() {
    SEARCH_URL="$API?action=query&list=search&srsearch=$(printf '%s' "$1" | jq -sRr @uri)&srlimit=40&format=json"
    curl -fsSL -A "$UA" "$SEARCH_URL"
}

SEARCH_RAW=$(fetch_search "$QUERY")
TITLES=$(echo "$SEARCH_RAW" | jq -r '.query.search[].title' 2>/dev/null)

if [ -z "$TITLES" ] || [ "$TITLES" = "null" ]; then
    echo "[!] No results found for '${QUERY}'."
    exit 1
fi

SELECTED_OUT=$(echo "$TITLES" | fzf --ansi --prompt="${BLUE}${BOLD}Wiki (${WIKI_LANG}) ❯ ${RESET}" \
    --layout=reverse --border=rounded --no-info \
    --header "ENTER: View | CTRL-O: Browser | CTRL-Y: Copy URL" \
    --preview-window="right:65%:wrap:border-left" \
    --expect="ctrl-o,ctrl-y" \
    --preview "$0 --preview-internal {}")

KEY=$(echo "$SELECTED_OUT" | head -n1)
SELECTED=$(echo "$SELECTED_OUT" | tail -n1)

if [ -n "$SELECTED" ]; then
    URL_WIKI="https://${WIKI_LANG}.wikipedia.org/wiki/$(printf '%s' "$SELECTED" | tr ' ' '_')"
    
    case "$KEY" in
        ctrl-o)
            command -v xdg-open >/dev/null 2>&1 && xdg-open "$URL_WIKI"
            command -v open >/dev/null 2>&1 && open "$URL_WIKI"
            ;;
        ctrl-y)
            copy_to_clipboard "$URL_WIKI"
            echo "Copied to clipboard: $URL_WIKI"
            ;;
        *)
            T_ENC=$(printf '%s' "$SELECTED" | jq -sRr @uri)
            URL_API="$API?action=query&titles=$T_ENC&prop=extracts&explaintext=1&format=json&redirects=1"
            RAW=$(curl -fsSL -A "$UA" "$URL_API")
            EXTRACT=$(echo "$RAW" | jq -r '.query.pages | to_entries[0].value.extract // ""' 2>/dev/null)
            [ -n "$EXTRACT" ] && render "$SELECTED" "$EXTRACT"
            ;;
    esac
fi
